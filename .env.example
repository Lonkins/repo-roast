# repo-roast configuration. Copy to .env.local (untracked) and fill in.
# Everything is optional: with no env at all, public roast mode works with
# the bundled template roaster.

# --- GitHub API (public mode) ---
# Optional server token to raise unauthenticated rate limits (60/h -> 5000/h).
# Needs NO scopes — create a fine-grained token with public repo read only.
# GITHUB_TOKEN=

# --- Private mode (self-host): GitHub OAuth App ---
# Register your own OAuth App: https://github.com/settings/applications/new
# Callback URL: <your-origin>/api/auth/callback/github
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# Generate with: openssl rand -base64 32
# AUTH_SECRET=
# Public origin of your instance, e.g. http://localhost:3000
# AUTH_URL=

# --- Deployment ---
# Absolute base URL for OG/Twitter share-card images (set in production).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Self-host (Docker) sets this to 1 to use the gitleaks binary over a full
# clone. Leave unset for the serverless API blob-walk strategy.
# GITLEAKS_BINARY=

# --- Comedy layer (optional; template roaster used when unset) ---
# One of: template (default) | anthropic | openai | ollama | claude-cli
# ROAST_PROVIDER=template
# ANTHROPIC_API_KEY=
# Reuse an existing Claude login instead of a pasted key: an OAuth bearer token
# (sent as Authorization: Bearer + the oauth beta header, never x-api-key).
# Source it from the supported CLI, e.g. `ant auth print-credentials
# --access-token`. Short-lived — refresh it, or prefer claude-cli below.
# ANTHROPIC_AUTH_TOKEN=
# OPENAI_API_KEY=
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# claude-cli: shell out to your locally-installed, already-authenticated
# `claude` CLI — repo-roast never sees a token. Self-host only (needs the
# binary on PATH). Override the binary name/path with CLAUDE_CLI_BIN.
# CLAUDE_CLI_BIN=claude
