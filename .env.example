# repo-roast configuration. Copy to .env.local (untracked) and fill in.
# Everything is optional: with no env at all, public roast mode works with
# the bundled template roaster.

# --- GitHub API (public mode) ---
# Optional server token to raise unauthenticated rate limits (60/h -> 5000/h).
# Needs NO scopes — create a fine-grained token with public repo read only.
# GITHUB_TOKEN=

# --- Private mode (self-host): GitHub OAuth App ---
# Register your own OAuth App: https://github.com/settings/applications/new
# Callback URL: <your-origin>/api/auth/callback/github
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# Generate with: openssl rand -base64 32
# AUTH_SECRET=
# Public origin of your instance, e.g. http://localhost:3000
# AUTH_URL=

# --- Comedy layer (optional; template roaster used when unset) ---
# One of: template (default) | anthropic | openai | ollama
# ROAST_PROVIDER=template
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
